// Eye Drop Reasons - Configurable from Admin Dashboard
model EyeDropReason {
  id        String   @id @default(cuid())
  reason    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("eye_drop_reasons")
}

model Equipment {
  id              String @id @default(cuid())
  name            String
  code            String? @unique
  category        String  // "Surgical Instruments", "Consumables", "Devices", "Medicine"
  manufacturer    String?
  currentStock    Int @default(0)
  reorderLevel    Int @default(5)
  unitCost        Float?
  expiryDate      DateTime?
  batchNumber     String?
  lastStockUpdate DateTime?
  isActive        Boolean @default(true)
  surgeryPackageId String? // Optional relation to surgery package
  
  // Medicine category specific fields
  register        String? // "FridgeStockMedicinesRegister", "EquipmentStockRegister", "OtEmergencyStockRegister"
  marginDate      DateTime? // Required for Medicine category
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  stockTransactions          StockTransaction[]
  surgeryPackage             SurgeryPackage? @relation(fields: [surgeryPackageId], references: [id])
  otEmergencyStockTracking   OtEmergencyStockRegister[] @relation("OtEmergencyStockTracking")
  fridgeStockTracking        FridgeStockMedicinesRegister[] @relation("FridgeStockTracking")
  equipmentStockTracking     EquipmentStockRegister[] @relation("EquipmentStockTracking")

  @@map("equipments")
}

model StockTransaction {
  id              String @id @default(cuid())
  transactionType String // "IN", "OUT", "EXPIRED", "ADJUSTMENT", "RETURNED"
  quantity        Int
  reason          String?
  transactionDate DateTime @default(now())
  performedBy     String
  
  // Either lens OR equipment (both nullable)
  lensId          String?
  equipmentId     String?
  ipdAdmissionId  String? // Track which surgery used it
  
  lens            Lens? @relation(fields: [lensId], references: [id])
  equipment       Equipment? @relation(fields: [equipmentId], references: [id])
  ipdAdmission    IpdAdmission? @relation(fields: [ipdAdmissionId], references: [id])

  @@map("stock_transactions")
}

// Unified Payment Model for OPD and IPD
model Payment {
  id                      String       @id @default(cuid())
  paymentNumber           String       @unique @default(cuid())
  
  // Patient and Visit/Admission references
  patientId               String
  patientVisitId          String?      @unique // For OPD payments
  ipdAdmissionId          String?      @unique // For IPD payments
  paymentType             PaymentType  // OPD or IPD
  
  // Billing amounts
  totalBilledAmount       Float        @default(0)
  totalPaidAmount         Float        @default(0)
  remainingAmount         Float        @default(0)
  
  // Payment breakdown
  paymentMode             PaymentMode  // FULL_CASH, FULL_ONLINE, HYBRID
  cashAmount              Float?       @default(0)
  onlineAmount            Float?       @default(0)
  
  // Online payment details (UPI, Card, NetBanking, etc.)
  onlinePaymentDetails    Json?        // {method: "UPI", transactionId: "", upiId: "", etc}
  
  // Insurance/TPA claim tracking
  claimApplied            Boolean      @default(false)
  claimStatus             ClaimStatus? @default(NOT_APPLIED)
  claimNumber             String?
  claimAmountRequested    Float?       @default(0)
  claimAmountSanctioned   Float?       @default(0)
  insuranceProviderId     String?
  claimSubmittedAt        DateTime?
  claimSettledAt          DateTime?
  claimRejectionReason    String?
  
  // Metadata
  paymentDate             DateTime     @default(now())
  createdBy               String       // Staff who recorded payment
  notes                   String?
  receiptGenerated        Boolean      @default(false)
  receiptPath             String?
  
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  
  // Relations
  patient                 Patient      @relation(fields: [patientId], references: [id])
  patientVisit            PatientVisit? @relation(fields: [patientVisitId], references: [id])
  ipdAdmission            IpdAdmission? @relation(fields: [ipdAdmissionId], references: [id])
  insuranceProvider       Insurance?   @relation(fields: [insuranceProviderId], references: [id])
  recordedBy              Staff        @relation(fields: [createdBy], references: [id])
  
  @@map("payments")
}

// ==================== NOTIFICATION SYSTEM ====================

model Notification {
  id              String   @id @default(cuid())
  title           String
  message         String   @db.Text
  type            String   // 'system', 'queue', 'emergency', 'appointment', 'surgery', 'billing', 'custom'
  priority        String   @default("normal") // 'low', 'normal', 'high', 'critical'
  
  // Targeting
  recipientType   String   // 'all', 'staff_type', 'specific_user', 'department'
  targetStaffTypes String[] @default([]) // e.g., ['doctor', 'nurse'] or empty for all
  targetUserIds   String[] @default([])  // specific user IDs if applicable
  targetDepartments String[] @default([]) // e.g., ['ophthalmology', 'surgery']
  
  // Metadata
  actionable      Boolean  @default(false)
  actionType      String?  // 'navigate', 'confirm', 'dismiss'
  actionData      Json?    // {url: '/path', params: {...}}
  
  // Sound
  playSound       Boolean  @default(true)
  soundType       String   @default("default") // 'default', 'urgent', 'subtle', 'custom'
  
  // Sender
  createdById     String?
  createdByType   String?  // 'super_admin', 'staff', 'system'
  
  // Status
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  readReceipts    NotificationReadReceipt[]

  @@index([type, isActive])
  @@index([createdAt])
  @@index([priority, isActive])
  @@map("notifications")
}

model NotificationReadReceipt {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  userType       String   // 'super_admin', 'staff', 'patient'
  readAt         DateTime @default(now())
  
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  
  @@unique([notificationId, userId, userType])
  @@index([userId, userType])
  @@map("notification_read_receipts")
}


model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String
  userType        String
  
  // Preferences
  enableSound     Boolean  @default(true)
  enablePush      Boolean  @default(true)
  enableEmail     Boolean  @default(false)
  
  // Type-specific settings
  mutedTypes      String[] @default([])
  mutedPriorities String[] @default([])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([userId, userType])
  @@map("notification_preferences")
}

model NotificationAudio {
  id              String   @id @default(cuid())
  name            String
  originalName    String
  description     String?
  filename        String   // Stored filename
  path            String   // Relative path
  mimeType        String
  size            Int
  
  // Configuration
  type            String   // 'emergency', 'completion', 'warning', 'info'
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("notification_audios")
}
