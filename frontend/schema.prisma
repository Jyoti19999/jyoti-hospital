generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StaffType {
  id   String @id @default(cuid())
  type String @unique

  @@map("staff_types")
}

model Hospital {
  id                 String    @id @default(cuid())
  hospitalName       String
  hospitalCode       String?   @unique
  registrationNumber String?
  licenseNumber      String?
  address            Json?
  phone              String?
  email              String?
  website            String?
  establishedDate    DateTime?
  hospitalType       String?
  accreditation      Json?
  totalBeds          Int?
  totalRooms         Int?
  totalFloors        Int?
  operatingHours     Json?
  emergencyServices  Boolean   @default(false)
  logo               String?
  timezone           String    @default("Asia/Kolkata")
  currency           String    @default("INR")
  supportedLanguages String[]  @default(["en", "hi"])
  configuration      Json?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  taxSettings        Json?
  bills              Bill[]

  @@map("hospital")
}

model Floor {
  id          String   @id @default(cuid())
  floorNumber Int
  floorName   String?
  floorType   String?
  accessible  Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  rooms       Room[]

  @@map("floors")
}

model RoomType {
  id                    String  @id @default(cuid())
  typeName              String
  typeCode              String? @unique
  category              String?
  defaultCapacity       Int?
  equipmentRequirements Json?
  costPerHour           Float?
  rooms                 Room[]

  @@map("room_types")
}

model Room {
  id                 String        @id @default(cuid())
  floorId            String?
  roomTypeId         String?
  roomNumber         String
  roomName           String?
  capacity           Int?
  equipmentInstalled Json?
  status             String        @default("available")
  dailyRate          Float?
  hourlyRate         Float?
  lastCleaned        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  assignedStaffId    String?
  appointments       Appointment[]
  beds               Bed[]
  assignedStaff      Staff?        @relation(fields: [assignedStaffId], references: [id])
  floor              Floor?        @relation(fields: [floorId], references: [id])
  roomType           RoomType?     @relation(fields: [roomTypeId], references: [id])

  @@map("rooms")
}

model BedType {
  id          String  @id @default(cuid())
  typeName    String
  typeCode    String? @unique
  category    String?
  dailyCharge Float?
  beds        Bed[]

  @@map("bed_types")
}

model Bed {
  id                    String    @id @default(cuid())
  roomId                String?
  bedTypeId             String?
  bedNumber             String
  status                String    @default("available")
  patientId             String?
  admissionDate         DateTime?
  expectedDischargeDate DateTime?
  dailyRate             Float?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  bedType               BedType?  @relation(fields: [bedTypeId], references: [id])
  patient               Patient?  @relation(fields: [patientId], references: [id])
  room                  Room?     @relation(fields: [roomId], references: [id])

  @@map("beds")
}

model Staff {
  id                          String                       @id @default(cuid())
  employeeId                  String?                      @unique
  firstName                   String
  middleName                  String?
  lastName                    String
  email                       String?                      @unique
  phone                       String?
  dateOfBirth                 DateTime?
  gender                      String?
  address                     Json?
  department                  String?
  staffType                   String
  employmentStatus            String                       @default("active")
  joiningDate                 DateTime?
  qualifications              Json?
  certifications              Json?
  languagesSpoken             String[]
  passwordHash                String?
  isActive                    Boolean                      @default(true)
  lastLogin                   DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  adminProfile                Json?
  doctorProfile               Json?
  emergencyContact            Json?
  nurseProfile                Json?
  optometristProfile          Json?
  receptionistProfile         Json?
  technicianProfile           Json?
  accountantProfile           Json?
  documents                   String[]
  patientSafetyOfficerProfile Json?
  profilePhoto                String?
  qualityCoordinatorProfile   Json?
  tpaProfile                  Json?
  receptionist2Profile        Json?
  anesthesiologistProfile     Json?
  otAdminProfile              Json?
  sisterProfile               Json?
  surgeonProfile              Json?
  appointments                Appointment[]
  diagnoses                   Diagnosis[]
  createdExaminationTemplates ExaminationTemplate[]
  examinations                Examination[]
  fitnessAssessments          FitnessReport[]              @relation("FitnessAssessor")
  admittedPatients            IpdAdmission[]               @relation("AdmittingStaff")
  performedSurgeries          IpdAdmission[]               @relation("SurgeonStaff")
  assistedSurgeries           IpdAdmission[]               @relation("SisterStaff")
  anesthesiaSurgeries         IpdAdmission[]               @relation("AnesthesiologistStaff")
  submittedClaims             IpdAdmission[]               @relation("ClaimSubmitter")
  approvedClaims              IpdAdmission[]               @relation("ClaimApprover")
  ophthalmologistExaminations OphthalmologistExamination[] @relation("OphthalmologistExaminations")
  optometristExaminations     OptometristExamination[]     @relation("OptometristExaminations")
  patientQueue                PatientQueue[]
  patientVisits               PatientVisit[]
  preOpAssessments            PreOpAssessment[]            @relation("PreOpAssessor")
  prescriptions               Prescription[]               @relation("DoctorPrescriptions")
  rooms                       Room[]
  attendance                  StaffAttendance[]
  surgeryMetrics              SurgeryMetrics[]             @relation("SurgeryPerformer")
  paymentsRecorded            Payment[]
  pushTokens                  PushToken[]
  @@map("staff")
}

model PushToken {
  id        String   @id @default(cuid())
  staffId   String
  token     String   @unique
  platform  String   @default("android") // android | ios
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("push_tokens")
}

model StaffAttendance {
  id               String           @id @default(cuid())
  staffId          String
  date             DateTime
  checkInTime      DateTime?
  checkOutTime     DateTime?
  workingHours     Float?
  isPresent        Boolean          @default(false)
  status           AttendanceStatus @default(ABSENT)
  
  // Location-based attendance fields
  attendanceMethod String?          // 'qr_scan', 'manual', 'location_based', 'biometric', etc.
  latitude         Float?           // GPS latitude for location-based attendance
  longitude        Float?           // GPS longitude for location-based attendance
  locationDistance Float?           // Distance from hospital center in meters
  locationAccuracy Float?           // GPS accuracy in meters
  locationData     Json?            // Additional location metadata
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  staff            Staff            @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([date])
  @@index([staffId])
  @@index([attendanceMethod])
  @@map("staff_attendance")
}

model Patient {
  id                 String           @id @default(cuid())
  mrn                String?          @unique
  firstName          String
  middleName         String?
  lastName           String
  dateOfBirth        DateTime?
  gender             String?
  phone              String?
  email              String?
  address            Json?
  emergencyContacts  Json?
  bloodGroup         String?
  allergies          Json?
  chronicConditions  Json?
  familyHistory      Json?
  eyeHistory         Json?
  visionHistory      Json?
  currentMedications Json?
  riskFactors        Json?
  insuranceDetails   Json?
  patientStatus      String           @default("active")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  lastLogin          DateTime?
  passwordHash       String?
  defaultInsuranceId String?
  patientNumber      Int?             @unique
  isReferred         Boolean          @default(false)
  referredBy         String?
  previousSurgeries  Json?
  profilePhoto       String?
  lifestyle          Json?
  appointments       Appointment[]
  beds               Bed[]
  bills              Bill[]
  insuranceClaims    InsuranceClaim[]
  ipdAdmissions      IpdAdmission[]
  patientQueue       PatientQueue[]
  patientVisits      PatientVisit[]
  defaultInsurance   Insurance?       @relation(fields: [defaultInsuranceId], references: [id])
  referrer           Patient?         @relation("PatientReferrals", fields: [referredBy], references: [id])
  referredPatients   Patient[]        @relation("PatientReferrals")
  payments           Payment[]

  @@map("patients")
}

model PatientVisit {
  id                          String                       @id @default(cuid())
  patientId                   String
  doctorId                    String?
  visitDate                   DateTime                     @default(now())
  chiefComplaint              String?
  presentingSymptoms          Json?
  visionComplaints            Json?
  eyeSymptoms                 Json?
  onsetDuration               String?
  priorityLevel               String?
  admissionDate               DateTime?
  dischargeDate               DateTime?
  estimatedCost               Float?
  insuranceCoverage           Float?
  visitOutcome                String?
  followUpInstructions        Json?
  nextAppointmentDate         DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  appointmentId               String                       @unique
  billingInitiatedAt          DateTime?
  checkedInAt                 DateTime                     @default(now())
  completedAt                 DateTime?
  doctorCalledAt              DateTime?
  doctorSeenAt                DateTime?
  followUpDate                DateTime?
  followUpRequired            Boolean                      @default(false)
  optometristCalledAt         DateTime?
  optometristSeenAt           DateTime?
  totalActualCost             Float?                       @default(0)
  totalEstimatedCost          Float?                       @default(0)
  status                      VisitStatus                  @default(CHECKED_IN)
  visitNumber                 Int?
  receptionist2Notes          String?
  visitType                   VisitType?                   @default(OPD)
  originalVisitId             String?                      // Link to original visit for follow-ups
  isFollowUp                  Boolean                      @default(false)
  paymentDone                 Boolean                      @default(false)
  paymentId                   String?
  bills                       Bill[]
  payment                     Payment?
  diagnoses                   Diagnosis[]
  examinations                Examination[]
  ipdAdmission                IpdAdmission?                @relation("IpdAdmissionVisit")
  surgeryDayAdmission         IpdAdmission?                @relation("SurgeryDayVisit")
  ophthalmologistExaminations OphthalmologistExamination[]
  optometristExamination      OptometristExamination?
  patientQueue                PatientQueue[]
  appointment                 Appointment                  @relation(fields: [appointmentId], references: [id])
  doctor                      Staff?                       @relation(fields: [doctorId], references: [id])
  patient                     Patient                      @relation(fields: [patientId], references: [id])
  prescriptions               Prescription[]

  @@unique([patientId, visitNumber])
  @@map("patient_visits")
}

model Icd11Code {
  id                    String    @id @default(cuid())
  foundationId          String    @unique
  code                  String?
  title                 Json?
  definition            Json?
  chapter               String?
  isEyeRelated          Boolean   @default(false)
  ophthalmologyCategory String?
  inclusionTerms        Json?
  exclusionTerms        Json?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  diseases              Disease[]

  @@map("icd11_codes")
}

model Disease {
  id                    String      @id @default(cuid())
  icd11CodeId           String?
  diseaseName           Json?
  commonNames           Json?
  ophthalmologyCategory String?
  affectedStructure     String?
  eyeAffected           String?
  symptoms              Json?
  signs                 Json?
  diagnosticCriteria    Json?
  treatmentProtocols    Json?
  surgicalOptions       Json?
  prognosis             Json?
  visualImpactLevel     String?
  urgencyLevel          String?
  isChronic             Boolean     @default(false)
  requiresSurgery       Boolean     @default(false)
  affectsVision         Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  diagnoses             Diagnosis[]
  icd11Code             Icd11Code?  @relation(fields: [icd11CodeId], references: [id])

  @@map("diseases")
}

model ExaminationTemplate {
  id                  String        @id @default(cuid())
  templateName        String
  examinationType     String?
  ophthalmologyType   String?
  requiredEquipment   String[]
  templateStructure   Json?
  formFields          Json?
  normalRanges        Json?
  visualAcuitySection Json?
  refractionSection   Json?
  slitLampSection     Json?
  fundoscopySection   Json?
  iopSection          Json?
  visualFieldSection  Json?
  version             String?
  isActive            Boolean       @default(true)
  createdBy           String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdByStaff      Staff?        @relation(fields: [createdBy], references: [id])
  examinations        Examination[]

  @@map("examination_templates")
}

model Examination {
  id                     String               @id @default(cuid())
  visitId                String
  templateId             String?
  doctorId               String
  examinationType        String?
  examinationDate        DateTime             @default(now())
  vitalSigns             Json?
  visualAcuity           Json?
  refraction             Json?
  intraocularPressure    Json?
  slitLampFindings       Json?
  fundoscopyFindings     Json?
  visualFieldResults     Json?
  colorVisionTest        Json?
  octFindings            Json?
  fundusPhotography      Json?
  fluoresceinAngiography Json?
  ultrasonography        Json?
  clinicalImpressions    String?
  assessment             Json?
  treatmentPlan          Json?
  images                 Json?
  reports                Json?
  followUpRequired       Boolean              @default(false)
  followUpDate           DateTime?
  status                 String               @default("completed")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  diagnoses              Diagnosis[]
  doctor                 Staff                @relation(fields: [doctorId], references: [id])
  template               ExaminationTemplate? @relation(fields: [templateId], references: [id])
  visit                  PatientVisit         @relation(fields: [visitId], references: [id])

  @@map("examinations")
}

model Diagnosis {
  id                           String                      @id @default(cuid())
  visitId                      String
  examinationId                String?
  diseaseId                    String?
  doctorId                     String
  diagnosisType                String?
  diagnosisDate                DateTime                    @default(now())
  confidenceLevel              Float?
  eyeAffected                  String?
  visualImpact                 String?
  severity                     String?
  stage                        String?
  onsetDate                    DateTime?
  progression                  String?
  diagnosticEvidence           Json?
  supportingFindings           Json?
  treatmentRecommended         Json?
  surgeryRequired              Boolean                     @default(false)
  urgencyLevel                 String?
  isPrimary                    Boolean                     @default(false)
  billable                     Boolean                     @default(true)
  notes                        String?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  ophthalmologistExaminationId String?
  disease                      Disease?                    @relation(fields: [diseaseId], references: [id])
  doctor                       Staff                       @relation(fields: [doctorId], references: [id])
  examination                  Examination?                @relation(fields: [examinationId], references: [id])
  ophthalmologistExamination   OphthalmologistExamination? @relation(fields: [ophthalmologistExaminationId], references: [id])
  visit                        PatientVisit                @relation(fields: [visitId], references: [id])

  @@map("diagnoses")
}

model Appointment {
  id                String            @id @default(cuid())
  patientId         String
  doctorId          String?
  appointmentDate   DateTime
  appointmentTime   String?
  tokenNumber       String            @unique
  qrCode            String?
  estimatedDuration Int?
  status            AppointmentStatus @default(SCHEDULED)
  appointmentType   String?
  purpose           String?
  notes             String?
  roomId            String?
  estimatedCost     Float?
  cancelReason      String?
  rescheduledFrom   String?
  rescheduledTo     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  doctor            Staff?            @relation(fields: [doctorId], references: [id])
  patient           Patient           @relation(fields: [patientId], references: [id])
  room              Room?             @relation(fields: [roomId], references: [id])
  patientVisit      PatientVisit?

  @@index([appointmentDate, status])
  @@map("appointments")
}

model PatientQueue {
  id                      String        @id @default(cuid())
  patientVisitId          String
  queueFor                QueueFor
  queueNumber             Int
  priority                Int           @default(0)
  status                  QueueStatus   @default(WAITING)
  assignedStaffId         String?
  estimatedWaitTime       Int?
  joinedAt                DateTime      @default(now())
  calledAt                DateTime?
  inProgressAt            DateTime?
  completedAt             DateTime?
  notes                   String?
  transferReason          String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  priorityLabel           PriorityLabel @default(ROUTINE)
  patientId               String
  doctorQueuePosition     Int?
  actualHoldDuration      Int?
  estimatedResumeTime     DateTime?
  holdReason              String?
  onHoldAt                DateTime?
  dilationRound           Int?          @default(0)
  lastDilationCheckAt     DateTime?
  customWaitMinutes       Int?
  markedReadyForResume    Boolean       @default(false)
  receptionist2Notes      String?
  receptionist2Reviewed   Boolean       @default(false)
  receptionist2ReviewedAt DateTime?
  receptionist2ReviewedBy String?
  resumedAt               DateTime?
  alarmPlayed             Boolean       @default(false)
  alarmPlayedAt           DateTime?
  assignedStaff           Staff?        @relation(fields: [assignedStaffId], references: [id])
  patient                 Patient       @relation(fields: [patientId], references: [id])
  patientVisit            PatientVisit  @relation(fields: [patientVisitId], references: [id])

  @@unique([queueFor, queueNumber, joinedAt])
  @@index([queueFor, status, priority, joinedAt])
  @@index([patientId])
  @@index([assignedStaffId, doctorQueuePosition])
  @@index([assignedStaffId, status, doctorQueuePosition])
  @@map("patient_queue")
}

model OptometristExamination {
  id                      String       @id @default(cuid())
  patientVisitId          String       @unique
  optometristId           String
  ucvaOD                  String?
  ucvaOS                  String?
  bcvaOD                  String?
  bcvaOS                  String?
  refractionSphereOD      Float?
  refractionCylinderOD    Float?
  refractionAxisOD        Int?
  refractionSphereOS      Float?
  refractionCylinderOS    Float?
  refractionAxisOS        Int?
  iopOD                   Float?
  iopOS                   Float?
  iopMethod               String?
  colorVision             String?
  pupilReaction           String?
  eyeAlignment            String?
  anteriorSegment         Json?
  preliminaryDiagnosis    String?
  urgencyLevel            String?
  additionalNotes         String?
  proceedToDoctor         Boolean      @default(true)
  requiresDilation        Boolean      @default(false)
  additionalTests         Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  additionalOrders        Json?
  additionalTestsLegacy   Json?
  assignedDoctor          String?
  clinicalDetails         Json?
  clinicalNotes           String?
  completedAt             DateTime?
  examinationStatus       String       @default("completed")
  knownAllergies          Json?
  refraction              Json?
  tonometry               Json?
  visualAcuity            Json?
  receptionist2Notes      String?
  receptionist2Reviewed   Boolean      @default(false)
  receptionist2ReviewedAt DateTime?
  receptionist2ReviewedBy String?
  optometrist             Staff        @relation("OptometristExaminations", fields: [optometristId], references: [id])
  patientVisit            PatientVisit @relation(fields: [patientVisitId], references: [id])

  @@map("optometrist_examinations")
}

model OphthalmologistExamination {
  id                      String         @id @default(cuid())
  patientVisitId          String
  doctorId                String
  examinationSequence     Int            @default(1)
  slitLampFindings        Json?
  fundoscopyFindings      Json?
  visualFieldResults      Json?
  octFindings             Json?
  fundusPhotography       Json?
  angiographyFindings     Json?
  ultrasonography         Json?
  clinicalImpressions     String?
  assessment              Json?
  treatmentPlan           Json?
  surgeryRecommended      Boolean        @default(false)
  urgencyLevel            String?
  followUpRequired        Boolean        @default(false)
  followUpDate            DateTime?
  followUpInstructions    Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  acdOD                   String?
  acdOS                   String?
  additionalNotes         String?
  additionalOrders        Json?
  additionalTests         Json?
  additionalTestsLegacy   Json?
  additionalTestsOrdered  Json?
  anteriorSegment         Json?
  anyOtherDetailsOD       String?
  anyOtherDetailsOS       String?
  assignedDoctor          String?
  axlOD                   String?
  axlOS                   String?
  bcvaOD                  String?
  bcvaOS                  String?
  clinicalDetails         Json?
  clinicalNotes           String?
  colorVision             String?
  completedAt             DateTime?
  conjunctivaOD           String?
  conjunctivaOS           String?
  corneaOD                String?
  corneaOS                String?
  coverTest               String?
  distanceBinocular       String?
  distanceOD              String?
  distanceOS              String?
  examinationNotes        String?
  examinationStatus       String         @default("completed")
  extraocularMovements    String?
  eyeAlignment            String?
  eyelidsOD               String?
  eyelidsOS               String?
  flatAxisOD              String?
  flatAxisOS              String?
  followUpDays            Int?
  followUpPeriod          String?
  iolImplantedOD          String?
  iolImplantedOS          String?
  iolPowerPlannedOD       String?
  iolPowerPlannedOS       String?
  iopMethod               String?
  iopOD                   Float?
  iopOS                   Float?
  k1OD                    String?
  k1OS                    String?
  k2OD                    String?
  k2OS                    String?
  knownAllergies          Json?
  lensOD                  String?
  lensOS                  String?
  nearBinocular           String?
  nearOD                  String?
  nearOS                  String?
  preliminaryDiagnosis    String?
  proceedToDoctor         Boolean        @default(true)
  pupilReaction           String?
  receptionist2Notes      String?
  receptionist2Reviewed   Boolean        @default(false)
  receptionist2ReviewedAt DateTime?
  receptionist2ReviewedBy String?
  refraction              Json?
  refractionAddOD         Float?
  refractionAddOS         Float?
  refractionAxisOD        Int?
  refractionAxisOS        Int?
  refractionCylinderOD    Float?
  refractionCylinderOS    Float?
  refractionPD            Float?
  refractionSphereOD      Float?
  refractionSphereOS      Float?
  requiresDilation        Boolean        @default(false)
  tonometry               Json?
  ucvaOD                  String?
  ucvaOS                  String?
  visualAcuity            Json?
  surgeryTypeId           String?
  diagnoses               Diagnosis[]
  doctor                  Staff          @relation("OphthalmologistExaminations", fields: [doctorId], references: [id])
  patientVisit            PatientVisit   @relation(fields: [patientVisitId], references: [id])
  surgeryType             SurgeryType?   @relation("SurgeryTypeExams", fields: [surgeryTypeId], references: [id])
  prescriptions           Prescription[]

  @@unique([patientVisitId, examinationSequence])
  @@map("ophthalmologist_examinations")
}

model Bill {
  id                      String          @id @default(cuid())
  billNumber              String          @unique
  patientId               String
  patientVisitId          String?
  hospitalId              String
  billDate                DateTime        @default(now())
  dueDate                 DateTime?
  status                  BillStatus      @default(DRAFT)
  subTotal                Float           @default(0)
  taxAmount               Float           @default(0)
  discountAmount          Float           @default(0)
  totalAmount             Float           @default(0)
  paidAmount              Float           @default(0)
  balanceAmount           Float           @default(0)
  billedBy                String?
  approvedBy              String?
  insuranceClaimId        String?
  estimatedInsuranceCover Float?          @default(0)
  notes                   String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  billItems               BillItem[]
  hospital                Hospital        @relation(fields: [hospitalId], references: [id])
  insuranceClaim          InsuranceClaim? @relation(fields: [insuranceClaimId], references: [id])
  patient                 Patient         @relation(fields: [patientId], references: [id])
  patientVisit            PatientVisit?   @relation(fields: [patientVisitId], references: [id])

  @@index([billDate, status])
  @@map("bills")
}

model BillItem {
  id             String   @id @default(cuid())
  billId         String
  itemType       ItemType
  itemCode       String?
  itemName       String
  description    String?
  quantity       Float    @default(1)
  unitPrice      Float
  totalPrice     Float
  taxRate        Float?   @default(0)
  taxAmount      Float?   @default(0)
  discountRate   Float?   @default(0)
  discountAmount Float?   @default(0)
  serviceId      String?
  examinationId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  bill           Bill     @relation(fields: [billId], references: [id])

  @@map("bill_items")
}

model Insurance {
  id               String           @id @default(cuid())
  insuranceName    String
  insuranceType    String
  policyNumber     String?
  coverageAmount   Float?
  deductibleAmount Float?
  copayPercentage  Float?
  validFrom        DateTime?
  validTo          DateTime?
  contactNumber    String?
  email            String?
  address          Json?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  insuranceClaims  InsuranceClaim[]
  patients         Patient[]
  payments         Payment[]

  @@map("insurance")
}

model InsuranceProvider {
  id                       String         @id @default(cuid())
  providerName             String         @unique
  providerCode             String?        @unique
  contactPerson            String?
  phoneNumber              String?
  email                    String?
  address                  String?
  city                     String?
  state                    String?
  pincode                  String?
  panNumber                String?
  gstNumber                String?
  websiteUrl               String?
  claimEmailId             String?
  claimPhoneNumber         String?
  supportEmail             String?
  supportPhone             String?
