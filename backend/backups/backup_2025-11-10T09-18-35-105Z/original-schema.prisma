// Medicine Master Models
model MedicineType {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  medicines Medicine[]

  @@map("medicine_types")
}

model GenericMedicine {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  medicines Medicine[]

  @@map("generic_medicines")
}

model DrugGroup {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  medicines Medicine[]

  @@map("drug_groups")
}

model DosageSchedule {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  medicines Medicine[]

  @@map("dosage_schedules")
}

model Medicine {
  id                String            @id @default(cuid())
  code              String?           @unique
  name              String
  typeId            String?
  genericMedicineId String?
  drugGroupId       String?
  dosageScheduleId  String?
  dosage            String?
  information       String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  type              MedicineType?     @relation(fields: [typeId], references: [id])
  genericMedicine   GenericMedicine?  @relation(fields: [genericMedicineId], references: [id])
  drugGroup         DrugGroup?        @relation(fields: [drugGroupId], references: [id])
  dosageSchedule    DosageSchedule?   @relation(fields: [dosageScheduleId], references: [id])
  prescriptionItems PrescriptionItem[]

  @@map("medicines")
}
