// Digital Register System - Dynamic register creation
model DigitalRegisterDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  columns     DigitalRegisterColumn[]
  records     DigitalRegisterRecord[]
  
  @@map("digital_register_definitions")
}

model DigitalRegisterColumn {
  id           String     @id @default(cuid())
  registerId   String
  columnName   String
  columnType   ColumnType
  isRequired   Boolean    @default(false)
  displayOrder Int
  minLength    Int?
  maxLength    Int?
  minValue     Float?
  maxValue     Float?
  pattern      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  register     DigitalRegisterDefinition @relation(fields: [registerId], references: [id], onDelete: Cascade)
  values       DigitalRegisterValue[]
  
  @@unique([registerId, columnName])
  @@map("digital_register_columns")
}

model DigitalRegisterRecord {
  id         String   @id @default(cuid())
  registerId String
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  register   DigitalRegisterDefinition @relation(fields: [registerId], references: [id], onDelete: Cascade)
  values     DigitalRegisterValue[]
  
  @@map("digital_register_records")
}

model DigitalRegisterValue {
  id          String    @id @default(cuid())
  recordId    String
  columnId    String
  textValue   String?
  numberValue Float?
  dateValue   DateTime?
  imageValue  String?   // File path or URL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  record      DigitalRegisterRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  column      DigitalRegisterColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  
  @@unique([recordId, columnId])
  @@map("digital_register_values")
}

enum ColumnType {
  TEXT
  NUMBER
  LONG_NUMBER
  DATE
  TIME
  DATETIME
  IMAGE
  EMAIL
  MOBILE
  URL
}
