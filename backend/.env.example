# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Application Configuration
APPLICATION_BASE_URL="http://localhost:8080/"
PORT=8080

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-here"

# Initial Admin User (for first setup)
INITIAL_ADMIN_EMAIL="admin@yourcompany.com"
INITIAL_ADMIN_PASSWORD="Admin@123"

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Display Information
EMAIL_FROM_NAME="OHMS - Eye Hospital"
EMAIL_FROM_ADDRESS="noreply@ohms.com"

# Environment
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:5173"

# Hospital Location Configuration for Attendance Geofencing
HOSPITAL_LATITUDE=18.64708126832894
HOSPITAL_LONGITUDE=73.84803671386994
HOSPITAL_GEOFENCE_RADIUS=100
